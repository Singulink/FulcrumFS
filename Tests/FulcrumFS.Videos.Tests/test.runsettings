<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <RunConfiguration>
    <TreatNoTestsAsError>false</TreatNoTestsAsError>
    <TestSessionTimeout>9000000</TestSessionTimeout>
  </RunConfiguration>
  <MSTest>
    <Parallelize>
      <Workers>1</Workers>
      <Scope>MethodLevel</Scope>
    </Parallelize>
    <CaptureTraceOutput>true</CaptureTraceOutput>
    <TestTimeout>300000</TestTimeout>
  </MSTest>
</RunSettings>
